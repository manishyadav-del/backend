# Root-level npm configuration for Turborepo workspace
# Windows and OneDrive compatibility

# Enable package-lock so Turborepo workspace mapping succeeds
package-lock=true

# Increase network timeouts for OneDrive sync delays
fetch-timeout=60000
fetch-retry-maxtimeout=120000

# Prevent audit and fund prompts during install
audit=false
fund=false

# Cache location outside OneDrive if possible
cache=C:\Users\manis\.npm-cache