generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== AUTH & USERS ==========
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // user, client, content_creator, author, contributor, admin
  status    String   @default("active") // active, inactive, suspended, pending
  avatar    String?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
  loginHistory LoginHistory[]
  passwordResetTokens PasswordResetToken[]
  roles            UserRole[]
  permissions      UserPermission[]
  auditLogs        AuditLog[]
  assignedPages    UserPage[]
  assignedServices UserService[]
  assignedMedia    UserMedia[]
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ip        String?
  userAgent String?
  location  String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ========== PROJECTS / WEBSITES ==========
model Project {
  id          String   @id @default(cuid())
  name        String
  domain      String?
  apiKey      String   @unique
  description String?
  logo        String?
  favicon     String?
  brandColor  String   @default("#3b82f6")
  status      String   @default("active") // active, maintenance, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pages       Page[]
  services    Service[]
  blogs       Blog[]
  media       Media[]
  contacts    Contact[]
  formSubmissions FormSubmission[]
  testimonials Testimonial[]
  faqs        FAQ[]
  teamMembers TeamMember[]
  legalPages  LegalPage[]
  navigation  Navigation[]
  leads       Lead[]
  notifications Notification[]
  backups     Backup[]
  settings    GlobalSetting?
  emailSettings EmailSetting?
  redirects   Redirect[]
  apiKeys     ApiKey[]
  ctas        CTA[]
  popups      Popup[]
  visitorSessions VisitorSession[]
}

// ========== PAGE MANAGEMENT ==========
model Page {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  title         String
  slug          String   @db.VarChar(50)
  path          String?
  status        String   @default("draft") @db.VarChar(20) // draft, published, archived, scheduled
  content       String?  // JSON content blocks (legacy)
  sections      String?  // JSON sections (legacy)
  banner        String?
  template      String?
  sortOrder     Int      @default(0)
  isHome        Boolean  @default(false)
  draftContent  String?  // JSON draft content (legacy)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  publishedAt   DateTime?
  scheduledAt   DateTime?
  authorId      String?
  visibility    String   @default("public") // public, private, password
  password      String?

  seo           SEO?
  faqs          FAQ[]
  schema        SchemaMarkup[]
  sections_rel  PageSection[]
  versions      PageVersion[]
  drafts        PageDraft[]
  assignedUsers UserPage[]

  @@unique([projectId, slug])
  @@index([projectId, status])
}

// ========== SEO MANAGEMENT ==========
model SEO {
  id            String   @id @default(cuid())
  pageId        String   @unique
  page          Page     @relation(fields: [pageId], references: [id])
  metaTitle     String?
  metaDescription String?
  urlSlug       String?
  canonical     String?
  ogImage       String?
  robots        String?
  llmTxt        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SchemaMarkup {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id])
  type      String   @default("json-ld")
  content   String   // JSON-LD content
  createdAt DateTime @default(now())
}

// ========== PAGE SECTIONS ==========
model PageSection {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id])
  type        String   // hero, about, services, features, cta, gallery, faq, testimonials, contact, custom, statistics, team
  title       String?
  content     String   // JSON content
  settings    String?  // JSON settings (background, padding, etc.)
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  parentId    String?  // for nested sections
  template    String?  // template variant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  children    PageSection[] @relation("SectionChildren")
  parent      PageSection?  @relation("SectionChildren", fields: [parentId], references: [id])
}

// ========== PAGE VERSIONS ==========
model PageVersion {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id])
  version     Int
  title       String
  slug        String
  content     String?  // JSON full page snapshot
  sections    String?  // JSON sections snapshot
  banner      String?
  seo         String?  // JSON SEO snapshot
  changeLog   String?  // description of changes
  createdBy   String?
  createdAt   DateTime @default(now())

  @@unique([pageId, version])
}

// ========== PAGE DRAFTS ==========
model PageDraft {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id])
  title       String
  slug        String
  content     String?  // JSON draft content
  sections    String?  // JSON draft sections
  banner      String?
  seo         String?  // JSON draft SEO
  changeLog   String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== SERVICE MANAGEMENT ==========
model Service {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  description String?
  image       String?
  ctaText     String?
  ctaLink     String?
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  faqs        FAQ[]
  assignedUsers UserService[]
}

// ========== BLOG / RESOURCES ==========
model Blog {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  content     String?
  excerpt     String?
  slug        String    @unique
  category    String?
  featuredImage String?
  author      String?
  status      String    @default("draft") // draft, published, scheduled
  publishedAt DateTime?
  scheduledAt DateTime?
  seoTitle    String?
  seoDescription String?
  targetPages String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, createdAt])
}

// ========== MEDIA LIBRARY ==========
model Media {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  filename    String
  originalName String
  url         String
  thumbnail   String?
  mimeType    String
  size        Int
  altText     String?
  folder      String   @default("root")
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignedUsers UserMedia[]
}

// ========== CONTACT DETAILS ==========
model Contact {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  type        String   // phone, email, address, whatsapp, maps, hours, social
  label       String?
  value       String
  icon        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== FORM SUBMISSIONS ==========
model FormSubmission {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  formType    String   @default("contact")
  name        String?
  email       String?
  phone       String?
  message     String?
  data        String?  // JSON extra fields
  status      String   @default("new") // new, read, replied, spam
  notes       String?
  leadId      String?
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
}

// ========== TESTIMONIALS ==========
model Testimonial {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  clientName String
  clientImage String?
  rating    Int      @default(5)
  content   String
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== FAQ MANAGEMENT ==========
model FAQ {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  question  String
  answer    String
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== TEAM MEMBERS ==========
model TeamMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  role      String?
  photo     String?
  bio       String?
  socialLinks String? @db.Text // JSON
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== LEGAL PAGES ==========
model LegalPage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  type        String   // privacy, terms, cookies, disclaimer, refund
  title       String
  content     String?
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== NAVIGATION / MENUS ==========
model Navigation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  location  String   // main, footer, mobile
  items     String   @db.Text // JSON array of menu items
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== LEADS ==========
model Lead {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  name        String?
  email       String?
  phone       String?
  serviceInterest String?
  sourcePage  String?
  source      String?  // form, popup, chatbot, etc.
  status      String   @default("new") // new, contacted, qualified, converted, lost
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, createdAt])
}

// ========== NOTIFICATIONS ==========
model Notification {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  type      String   // lead, form, blog, system
  title     String
  message   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ========== BACKUPS ==========
model Backup {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  type      String   // database, media, full
  fileUrl   String?
  size      Int?
  status    String   @default("completed")
  createdAt DateTime @default(now())
}

// ========== GLOBAL SETTINGS ==========
model GlobalSetting {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id])
  logo      String?
  favicon   String?
  brandColor String  @default("#3b82f6")
  headerSettings String? @db.Text // JSON
  footerSettings String? @db.Text // JSON
  maintenanceMode Boolean @default(false)
  defaultContact  String? @db.Text // JSON
  analytics  String? @db.Text // JSON - GA, Clarity, etc IDs
  cookieConsent  Boolean @default(true)
  formConsent    Boolean @default(true)
  privacyAccept  Boolean @default(true)
  marketingConsent Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== EMAIL SETTINGS ==========
model EmailSetting {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id])
  smtpHost  String?
  smtpPort  Int?
  smtpUser  String?
  smtpPass  String?
  formEmail String?
  autoReplyTemplate String?
  adminAlerts Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== REDIRECTS ==========
model Redirect {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  fromPath  String
  toPath    String
  type      String   @default("301") // 301, 302
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== API KEYS ==========
model ApiKey {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  key       String   @unique
  permissions String? // JSON array
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== CTA MANAGEMENT ==========
model CTA {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  buttonText  String
  link        String?
  type        String   @default("button") // button, floating, banner
  placement   String   @default("global") // global, homepage, all, specific
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  bgColor     String?
  textColor   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// ========== POPUP MANAGEMENT ==========
model Popup {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  content     String?
  type        String   @default("info") // info, newsletter, lead-magnet
  trigger     String   @default("exit") // exit, time, scroll, click
  delay       Int      @default(5)
  isActive    Boolean  @default(true)
  buttonText  String?
  buttonLink  String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// ========== VISITOR SESSIONS ==========
model VisitorSession {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  sessionId   String   @unique
  page        String
  userAgent   String?  @db.Text
  ip          String?
  country     String?
  device      String?  // desktop, mobile, tablet
  browser     String?
  source      String?  // direct, google, social, etc.
  duration    Int      @default(0)
  isActive    Boolean  @default(true)
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([projectId, isActive])
  @@index([lastSeen])
}

// ========== ERROR LOGS ==========
model ErrorLog {
  id        String   @id @default(cuid())
  projectId String?
  level     String   @default("error") // error, warn, info
  message   String   @db.Text
  stack     String?  @db.Text
  url       String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
}

// ========== RBAC & AUDIT LOGS ==========

model Role {
  id          String   @id @default(cuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(cuid()) @db.VarChar(50)
  module    String   @db.VarChar(50) // e.g. "pages", "seo"
  action    String   @db.VarChar(50) // e.g. "view", "edit"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles     RolePermission[]
  users     UserPermission[]

  @@unique([module, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @db.VarChar(50)
  permissionId String     @db.VarChar(50)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String @db.VarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String     @db.VarChar(50)
  value        Boolean    @default(true) // true to allow, false to deny (override)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  module    String?
  timestamp DateTime @default(now())
  ipAddress String?

  @@index([userId])
}

model UserPage {
  id     String @id @default(cuid())
  userId String
  pageId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model UserService {
  id        String  @id @default(cuid())
  userId    String
  serviceId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model UserMedia {
  id      String @id @default(cuid())
  userId  String
  mediaId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

// ========== WEBSITE CONNECTOR SYSTEM ==========

model ConnectedWebsite {
  id              String   @id @default(cuid()) @db.VarChar(50)
  name            String
  domain          String   @unique @db.VarChar(191)
  ipAddress       String   @db.VarChar(50)
  apiUrl          String?  @db.VarChar(191)
  dbHost          String?  @db.VarChar(100)
  dbPort          Int?
  dbUser          String?  @db.VarChar(100)
  dbPassword      String?  @db.Text
  dbName          String?  @db.VarChar(100)
  authToken       String   @db.Text
  framework       String   @db.VarChar(50) // "nextjs", "react", "wordpress", "laravel", etc.
  frameworkVersion String?  @db.VarChar(50)
  sdkVersion      String?  @db.VarChar(50)
  status          String   @default("connected") @db.VarChar(20) // connected, disconnected, error
  syncStatus      String   @default("synced") @db.VarChar(20) // synced, syncing, error
  environment     String   @default("production") @db.VarChar(50)
  ownerInfo       String?  @db.VarChar(191)
  modules         String?  @db.Text // JSON configuration of active modules
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  routes          ConnectedRoute[]
  activityLogs    ConnectedWebsiteLog[]
  discoveredApis  DiscoveredApi[]
  moduleAssignments ModuleAssignment[]
  syncLogs          WebsiteSyncLog[]
}

model DiscoveredApi {
  id          String           @id @default(cuid()) @db.VarChar(50)
  websiteId   String           @db.VarChar(50)
  website     ConnectedWebsite @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  method      String           @db.VarChar(10) // GET, POST, PUT, PATCH, DELETE
  path        String           @db.VarChar(120)
  description String?          @db.VarChar(191)
  createdAt   DateTime         @default(now())

  @@unique([websiteId, method, path])
}

model ConnectedRoute {
  id                 String           @id @default(cuid()) @db.VarChar(50)
  websiteId          String           @db.VarChar(50)
  website            ConnectedWebsite @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  path               String           @db.VarChar(191) // e.g. "/about"
  title              String
  content            String?          @db.LongText // JSON content: text, images, banners, forms, menus, page sections
  metaTitle          String?
  metaDescription    String?
  status             String           @default("active") @db.VarChar(20) // active, draft, inactive
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([websiteId, path])
}

model ConnectedWebsiteLog {
  id           String           @id @default(cuid()) @db.VarChar(50)
  websiteId    String           @db.VarChar(50)
  website      ConnectedWebsite @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  action       String           @db.VarChar(50) // e.g. "CONNECT", "SYNC", "UPDATE_ROUTE", "DELETE_ROUTE"
  status       String           @db.VarChar(20) // "success", "failure"
  details      String?          @db.Text
  createdAt    DateTime         @default(now())
}

model ConnectedWebsiteModule {
  id          String   @id @default(cuid()) @db.VarChar(50)
  key         String   @unique @db.VarChar(50) // e.g. "dashboard", "content", "crm", "analytics", "builder", "reputation", "seo", "security", "users", "system", "legal"
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  status      String   @default("active") @db.VarChar(20) // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ModuleAssignment[]
}

model ModuleAssignment {
  id           String                 @id @default(cuid()) @db.VarChar(50)
  websiteId    String                 @db.VarChar(50)
  website      ConnectedWebsite       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  moduleId     String                 @db.VarChar(50)
  module       ConnectedWebsiteModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status       String                 @default("enabled") @db.VarChar(20) // enabled, disabled
  lastSyncedAt DateTime?
  syncStatus   String                 @default("synced") @db.VarChar(20) // synced, error, pending
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([websiteId, moduleId])
}

model WebsiteSyncLog {
  id         String           @id @default(cuid()) @db.VarChar(50)
  websiteId  String           @db.VarChar(50)
  website    ConnectedWebsite @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  moduleKey  String           @db.VarChar(50) // e.g., "seo", "content"
  action     String           @db.VarChar(50) // e.g., "SYNC_SEO", "SYNC_TEMPLATES"
  status     String           @db.VarChar(20) // success, failure
  errorMsg   String?          @db.Text
  createdAt  DateTime         @default(now())
}

// ========== NEW WEBSITES CONNECTOR SDK MODELS ==========

model Website {
  id              String         @id @default(cuid()) @db.VarChar(50)
  name            String
  domain          String         @unique @db.VarChar(191)
  framework       String         @db.VarChar(50)
  frameworkVersion String?        @db.VarChar(50)
  sdkVersion       String?        @db.VarChar(50)
  environment      String?        @db.VarChar(50)
  apiKey          String?        @unique @db.VarChar(191)
  syncToken       String?        @db.Text
  status          String         @default("connected") @db.VarChar(20)
  lastSyncedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tokens          WebsiteToken[]
  routes          WebsiteRoute[]
  pages           WebsitePage[]
  modules         WebsiteModule[]
  components      WebsiteComponent[]
  media           WebsiteMedia[]
  syncJobs        SyncJob[]
  syncLogs        SyncLog[]
}

model WebsiteToken {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  token           String         @unique @db.VarChar(191)
  expiresAt       DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
}

model WebsiteRoute {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  path            String         @db.VarChar(150)
  title           String?        @db.VarChar(191)
  routeType       String         @default("page") @db.VarChar(20) // page, api, dynamic
  isDynamic       Boolean        @default(false)
  status          String         @default("active") @db.VarChar(20)
  assignedModule  String?        @db.VarChar(50)  // cms, blog, seo, forms, legal, analytics, media, settings
  moduleConfig    String?        @db.Text          // JSON: custom config per module assignment
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([websiteId, path])
}

model WebsitePage {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  slug            String         @db.VarChar(150)
  title           String         @db.VarChar(191)
  content         String?        @db.LongText
  seoTitle        String?        @db.VarChar(191)
  seoDesc         String?        @db.Text
  ogImage         String?        @db.VarChar(191)
  status          String         @default("published") @db.VarChar(20)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([websiteId, slug])
}

model WebsiteModule {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  key             String         @db.VarChar(50)
  status          String         @default("enabled") @db.VarChar(20)
  config          String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([websiteId, key])
}

model WebsiteMedia {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  filename        String         @db.VarChar(191)
  url             String         @db.VarChar(191)
  mimeType        String         @db.VarChar(100)
  size            Int
  altText         String?        @db.VarChar(191)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SyncJob {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  type            String         @db.VarChar(50)
  status          String         @default("pending") @db.VarChar(20)
  payload         String?        @db.LongText
  error           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model SyncLog {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  action          String         @db.VarChar(50)
  status          String         @db.VarChar(20)
  details         String?        @db.LongText
  createdAt       DateTime       @default(now())
}

model WebsiteComponent {
  id              String         @id @default(cuid()) @db.VarChar(50)
  websiteId       String         @db.VarChar(50)
  website         Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  name            String         @db.VarChar(50)
  filePath        String         @db.VarChar(191)
  route           String         @db.VarChar(100)
  componentType   String         @default("Section") @db.VarChar(50) // Section, Widget, Module, Component
  props           String?        @db.Text          // JSON string array of discovered props
  data            String?        @db.Text          // JSON object values
  previewImage    String?        @db.VarChar(255)
  status          String         @default("active") @db.VarChar(20)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([websiteId, name, route])
}